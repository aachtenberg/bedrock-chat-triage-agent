aws_region          = "us-east-1"
project_name        = "bedrock-chat"
environment         = "dev"
bedrock_model_id    = "anthropic.claude-sonnet-4-5-20250929-v1:0"
# For Sonnet 4.5, set this to an inference profile ARN if your account does not support on-demand use for the model.
# bedrock_agent_foundation_model = "arn:aws:bedrock:us-east-1:123456789012:inference-profile/your-profile-id"

# --- Auth mode ---
# "cognito"  — Cognito SSO via Microsoft Entra ID / Azure AD (default, recommended)
# "basic"    — HTTP Basic Auth (simpler, no Azure app registration required)
# "otp"      — Email one-time password (no SSO provider needed; requires SES verified sender)
# Option A: Cognito SSO (auth_mode = "cognito")
# ============================================================
# Register a free app at https://portal.azure.com:
#   1. App registrations → New registration
#   2. Name: anything (e.g. "bedrock-chat-dev")
#   3. Supported account types: "Accounts in any org directory AND personal Microsoft accounts"
#   4. Redirect URI: leave blank for now — Terraform prints the correct callback URL after first apply
#   5. After creation: Certificates & secrets → New client secret → copy value immediately
#   6. Copy Application (client) ID from the app overview page
cognito_oidc_client_id     = "your-azure-app-client-id"
cognito_oidc_client_secret = "your-azure-app-client-secret"

# Use the specific tenant ID (not /common/) to avoid id_token issuer mismatch errors.
# cognito_oidc_issuer = "https://login.microsoftonline.com/<tenant-id>/v2.0"
cognito_oidc_issuer = "https://login.microsoftonline.com/common/v2.0"

# Two-step deploy: leave empty on first apply.
# After apply: copy the cloudfront_url output (without https://) here and re-apply.
# Terraform will then register the real callback URL with the Cognito app client.
cloudfront_domain = ""

# ============================================================
# Option B: HTTP Basic Auth (auth_mode = "basic")
# ============================================================
# No Azure/Cognito setup required. The browser shows a native login dialog.
# basic_auth_username = "admin"
# basic_auth_password = "change-me-in-production"

# ============================================================
# Option C: Email OTP (auth_mode = "otp")
# ============================================================
# Users enter their work email; a 6-digit code is sent via SES.
# No Azure/Cognito setup needed. Requires SES sender verification (see below).
#
# 1. Verify your sender address in SES (run once):
#      aws ses verify-email-identity --email-address noreply@example.com --region us-east-1
#    Or verify your entire domain via SES domain identity (adds DNS TXT records).
#    Note: new AWS accounts are in SES sandbox — recipient emails must also be verified
#    until you request production access via the AWS console.
#
# 2. Set the variables below in terraform.tfvars (this file is gitignored so secrets stay private).
#
# auth_mode          = "otp"
# otp_sender_email   = "noreply@example.com"
# otp_allowed_email_domains = ["example.com"]   # restrict to specific domains; [] = allow any
# otp_ttl_seconds    = 600                       # code expiry in seconds (default: 10 min)
